{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@collab-board/*": ["packages/*/src"]
    },
    "resolveJsonModule": true
  },
  "exclude": ["node_modules", "dist", "coverage"]
}